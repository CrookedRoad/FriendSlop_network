function scr_IAV_encode(argument0){
var _stringRaw = argument0;
var _stringEncode = "";
	for(var _l=0; _l<string_length(_stringRaw); _l++)
	{
	var _letter = string_copy(_stringRaw, (_l+1), 1);
		_letter = global.IAVguard[? string(_letter)];
		_stringEncode += _letter;
	}
	
return(_stringEncode);
}

function scr_IAV_decode(argument0){
var _stringRaw = argument0;
var _stringLength = string_length(_stringRaw)/5;
var _stringDecode = "";
	for(var _l=0; _l<_stringLength; _l++)
	{
	var _letter = string_copy(_stringRaw, (_l*5)+1, 5);
		_letter = global.IAVguard[? string(_letter)];
		_stringDecode += _letter;
	}
	
return(_stringDecode);
}